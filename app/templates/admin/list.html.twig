{% extends 'base.html.twig' %}

{% block title %}Gestion des produits{% endblock %}

{% block body %}
{% for type, messages in app.flashes %}
    {% for message in messages %}
        <div class="alert alert-{{ type }} alert-dismissible fade show" role="alert">
            {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endfor %}
{% endfor %}
 <div class="text-center mb-4">
    <h1>Gestion des produits</h1>
    <a href="{{ path('app_admin_new') }}" class="btn btn-primary mb-3 badge bg-primary ">
        +
    </a>
 </div>

    <table class="table table-striped table-hover">
        <thead class="table-light">
            <tr>
                <th>Titre</th>
                <th>Prix</th>
                <th>Catégorie</th>
                <th>Modifier</th>
                <th>Supprimer</th>
            </tr>
        </thead>
        <tbody>
            {% for product in products %}
                <tr>
                    <td>
                        <a href="#">
                            {{ product.title }}
                        </a>
                    </td>
                    <td>{{ product.price }} €</td>
                    <td>{{ product.category.name }}</td>
                    <td>
                        <a href="{{path('app_admin_edit',{id:product.id})}}" class="btn btn-warning btn-sm">✏️</a>
                    </td>
                    <td>
                        <a href="{{path('app_admin_delete',{id:product.id})}}" 
                        class="btn btn-danger btn-sm"
                        onclick="return confirm('voulez-vous vraiment supprimer ce produit?')">❌</a>
                        
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="5" class="text-center">Aucun produit trouvé.</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
     <div class="text-center">
    <a href="{{ path('app_admin_index') }}" class="btn btn-primary ">
        Retour espace administrateur
    </a>
    </div>
{% endblock %}