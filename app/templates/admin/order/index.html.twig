{% extends 'admin/base.html.twig' %}

{% block title %}Commandes{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">Commandes</h1>
    <span class="badge bg-secondary fs-6">{{ orders|length }} commande{{ orders|length > 1 ? 's' : '' }}</span>
</div>

<div class="card">
    <div class="card-body p-0">
        {% if orders is empty %}
            <p class="text-muted text-center py-4 mb-0">Aucune commande enregistrée.</p>
        {% else %}
            <table class="table table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th scope="col">#</th>
                        <th scope="col">Client</th>
                        <th scope="col">Date</th>
                        <th scope="col">Montant</th>
                        <th scope="col">Statut</th>
                        <th scope="col" class="text-end">Action</th>
                    </tr>
                </thead>
                <tbody>
                    {% for order in orders %}
                    {% set badgeClass = {
                        'pending_payment': 'bg-warning text-dark',
                        'paid':            'bg-info text-dark',
                        'shipped':         'bg-primary',
                        'delivered':       'bg-success',
                        'canceled':        'bg-danger'
                    } %}
                    <tr>
                        <td class="text-muted">{{ order.id }}</td>
                        <td>{{ order.user.email }}</td>
                        <td>{{ order.createdAt|date('d/m/Y H:i') }}</td>
                        <td class="fw-semibold">{{ order.totalAmount|number_format(2, ',', ' ') }} €</td>
                        <td>
                            <span class="badge {{ badgeClass[order.status] ?? 'bg-secondary' }}">
                                {{ order.status }}
                            </span>
                        </td>
                        <td class="text-end">
                            <a href="{{ path('admin_order_edit', {id: order.id}) }}"
                               class="btn btn-sm btn-warning">
                                ✏️ Modifier
                            </a>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% endif %}
    </div>
</div>
{% endblock %}
