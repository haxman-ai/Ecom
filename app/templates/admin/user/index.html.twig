{% extends 'admin/base.html.twig' %}

{% block title %}Utilisateurs{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">Utilisateurs</h1>
    <span class="badge bg-secondary fs-6">{{ users|length }} utilisateur{{ users|length > 1 ? 's' : '' }}</span>
</div>

<div class="card">
    <div class="card-body p-0">
        {% if users is empty %}
            <p class="text-muted text-center py-4 mb-0">Aucun utilisateur enregistré.</p>
        {% else %}
            <table class="table table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th scope="col">#</th>
                        <th scope="col">Email</th>
                        <th scope="col">Rôles</th>
                        <th scope="col">Vérifié</th>
                        <th scope="col" class="text-end">Action</th>
                    </tr>
                </thead>
                <tbody>
                    {% for user in users %}
                    <tr>
                        <td class="text-muted">{{ user.id }}</td>
                        <td class="fw-semibold">
                            {{ user.email }}
                            {% if user == app.user %}
                                <span class="badge bg-info ms-1">Vous</span>
                            {% endif %}
                        </td>
                        <td>
                            {% for role in user.roles %}
                                <span class="badge {{ role == 'ROLE_ADMIN' ? 'bg-danger' : 'bg-secondary' }}">
                                    {{ role }}
                                </span>
                            {% endfor %}
                        </td>
                        <td>
                            {% if user.verified %}
                                <span class="badge bg-success">Oui</span>
                            {% else %}
                                <span class="badge bg-warning text-dark">Non</span>
                            {% endif %}
                        </td>
                        <td class="text-end">
                            <button type="button"
                                    class="btn btn-sm btn-danger"
                                    {{ user == app.user ? 'disabled' : '' }}
                                    data-bs-toggle="modal"
                                    data-bs-target="#modalDelete"
                                    data-user-id="{{ user.id }}"
                                    data-user-email="{{ user.email }}"
                                    data-csrf-token="{{ csrf_token('delete_user_' ~ user.id) }}">
                                🗑️ Supprimer
                            </button>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% endif %}
    </div>
</div>

{# Modale de confirmation — une seule instance partagée #}
<div class="modal fade" id="modalDelete" tabindex="-1" aria-labelledby="modalDeleteLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalDeleteLabel">Confirmer la suppression</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                Supprimer l'utilisateur <strong id="modalUserEmail"></strong> ?
                Cette action est irréversible.
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                <form id="deleteForm" method="POST">
                    <input type="hidden" name="_method" value="DELETE">
                    <input type="hidden" name="_token" id="csrfToken">
                    <button type="submit" class="btn btn-danger">Confirmer la suppression</button>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    document.getElementById('modalDelete').addEventListener('show.bs.modal', function (event) {
        const button = event.relatedTarget;
        const userId = button.dataset.userId;
        const userEmail = button.dataset.userEmail;

        document.getElementById('modalUserEmail').textContent = userEmail;
        document.getElementById('deleteForm').action = '/admin/users/' + userId + '/delete';
        document.getElementById('csrfToken').value = button.dataset.csrfToken;
    });
</script>
{% endblock %}
