{% extends 'admin/base.html.twig' %}

{% block title %}Catégories{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">Catégories</h1>
    <span class="badge bg-secondary fs-6">{{ categories|length }} catégorie{{ categories|length > 1 ? 's' : '' }}</span>
</div>

<div class="card">
    <div class="card-body p-0">
        {% if categories is empty %}
            <p class="text-muted text-center py-4 mb-0">Aucune catégorie enregistrée.</p>
        {% else %}
            <table class="table table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th scope="col">#</th>
                        <th scope="col">Nom</th>
                        <th scope="col">Couleur</th>
                    </tr>
                </thead>
                <tbody>
                    {% for category in categories %}
                    <tr>
                        <td class="text-muted">{{ category.id }}</td>
                        <td class="fw-semibold">{{ category.name }}</td>
                        <td>
                            <span class="badge rounded-pill" style="background-color: {{ category.color }}">
                                {{ category.color }}
                            </span>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% endif %}
    </div>
</div>
{% endblock %}
