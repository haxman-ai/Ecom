<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">

        <title>{% block title %}Esprit Déco{% endblock %}</title>

        <meta name="viewport" content="width=device-width, initial-scale=1">

        <link href="https://cdn.jsdelivr.net/npm/bootswatch@5.3.3/dist/superhero/bootstrap.min.css" rel="stylesheet">
        <link href="{{ asset('styles/base.css') }}" rel="stylesheet">
        {% block stylesheets %}{% endblock %}
    </head>

    <body>
        {% include '_shared/_header.html.twig' %}
        {% include '_shared/_nav.html.twig' %}

        <main>
            {% block body %}{% endblock %}
        </main>

        {% include '_shared/_footer.html.twig' %}

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

        {% block javascripts %}{% endblock %}
    </body>
</html>