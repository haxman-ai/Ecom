<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">

        <title>{% block title %}Esprit Déco{% endblock %}</title>

        <meta name="viewport" content="width=device-width, initial-scale=1">

        <link href="https://cdn.jsdelivr.net/npm/bootswatch@5.3.3/dist/superhero/bootstrap.min.css" rel="stylesheet">
        <link href="{{ asset('styles/base.css') }}" rel="stylesheet">
        {% block stylesheets %}{% endblock %}
    </head>

    <body>
        {% include '_shared/_header.html.twig' %}
        {% include '_shared/_nav.html.twig' %}

        <main>
            {% block body %}{% endblock %}
        </main>

        {% include '_shared/_footer.html.twig' %}
        <div class="offcanvas offcanvas-end" id="cartPanel">
    <div class="offcanvas-header">
        <h5 class="offcanvas-title">Mon panier</h5>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas"></button>
    </div>
        <div class="offcanvas-body">
            {# le contenu du panier ici #}
        </div>
    </div>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

        {% block javascripts %}
           
        <script>
            document.getElementById('add-image').addEventListener('click', function() {
            const input = document.createElement('input');
            input.type = 'file';
            input.name = 'imageFile[]';
            const container = document.getElementById('upload-container');
            container.appendChild(input);
            }); 
        </script>
        {% endblock %}
    </body>
</html>