{% extends 'base.html.twig' %}

{% block title %}Paiement confirmé — Esprit Déco{% endblock %}

{% block body %}
<div class="container py-5 text-center">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="mb-4" style="font-size: 4rem;">✅</div>
            <h2 class="mb-2">Paiement confirmé !</h2>
            <p class="text-muted mb-4">
                Merci pour votre commande #{{ order.id }}.<br>
                Vous recevrez une confirmation par email.
            </p>

            <div class="card text-start mb-4">
                <div class="card-header fw-semibold">Récapitulatif</div>
                <ul class="list-group list-group-flush">
                    {% for line in order.orderLines %}
                    <li class="list-group-item d-flex justify-content-between">
                        <span>{{ line.product.title }} × {{ line.quantity }}</span>
                        <span>{{ (line.unitPrice * line.quantity)|number_format(2, ',', ' ') }} €</span>
                    </li>
                    {% endfor %}
                    <li class="list-group-item d-flex justify-content-between fw-bold">
                        <span>Total payé</span>
                        <span>{{ order.totalAmount|number_format(2, ',', ' ') }} €</span>
                    </li>
                </ul>
            </div>

            <a href="{{ path('app_home') }}" class="btn btn-primary">Retour à la boutique</a>
        </div>
    </div>
</div>
{% endblock %}
