{% extends 'base.html.twig' %}

{% block title %}Récapitulatif de commande #{{ order.id }} — Esprit Déco{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-7">

            <h2 class="mb-1">Récapitulatif de votre commande</h2>
            <p class="text-muted mb-4">
                Commande #{{ order.id }} — passée le {{ order.createdAt|date('d/m/Y à H:i') }}
            </p>

            <div class="card mb-4">
                <div class="card-header fw-semibold">Adresse de livraison</div>
                <div class="card-body">
                    <p class="mb-1">{{ order.address.fullname }}</p>
                    <p class="mb-1">{{ order.address.street }}</p>
                    <p class="mb-0">{{ order.address.zipCode }} {{ order.address.city }}</p>
                </div>
            </div>

            <div class="card mb-4">
                <div class="card-header fw-semibold">Articles commandés</div>
                <ul class="list-group list-group-flush">
                    {% for line in order.orderLines %}
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <div>
                            <span class="fw-medium">{{ line.product.title }}</span>
                            <small class="text-muted ms-2">{{ line.unitPrice|number_format(2, ',', ' ') }} € / unité</small>
                        </div>
                        <div class="text-end">
                            <span class="badge bg-secondary me-2">× {{ line.quantity }}</span>
                            <span>{{ (line.unitPrice * line.quantity)|number_format(2, ',', ' ') }} €</span>
                        </div>
                    </li>
                    {% endfor %}
                    <li class="list-group-item d-flex justify-content-between fw-bold fs-5">
                        <span>Total</span>
                        <span>{{ order.totalAmount|number_format(2, ',', ' ') }} €</span>
                    </li>
                </ul>
            </div>

            <div class="d-flex gap-2">
                <a href="{{ path('checkout_address') }}" class="btn btn-outline-secondary flex-fill">
                    Modifier l'adresse
                </a>
                <a href="#" class="btn btn-success flex-fill">
                    Confirmer et payer
                </a>
            </div>

        </div>
    </div>
</div>
{% endblock %}
