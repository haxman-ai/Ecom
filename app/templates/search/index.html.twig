{% extends 'base.html.twig' %}

{% block title %}Recherche{% if keyword %} — {{ keyword }}{% endif %} — Esprit Déco{% endblock %}

{% block body %}
<div class="container py-4">

    {# Barre de recherche #}
    {{ form_start(form, {attr: {class: 'mb-4'}}) }}
    <div class="input-group">
        {{ form_widget(form.keyword) }}
        <button type="submit" class="btn btn-primary">Rechercher</button>
    </div>
    {{ form_end(form) }}

    {# En-tête des résultats #}
    {% if keyword %}
        <p class="text-muted mb-3">
            {{ products|length }} résultat{{ products|length > 1 ? 's' : '' }}
            pour <strong>« {{ keyword }} »</strong>
        </p>
    {% endif %}

    {# Aucun résultat #}
    {% if products is empty %}
        <div class="alert alert-warning">
            Aucun produit ne correspond à votre recherche.
            <a href="{{ path('app_search') }}" class="alert-link">Voir tous les produits</a>
        </div>
    {% else %}
        {# Grille de résultats #}
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-4 g-4">
            {% for product in products %}
            <div class="col">
                <div class="card h-100">
                    {% set principalImage = null %}
                    {% for image in product.images %}
                        {% if image.isPrincipal %}
                            {% set principalImage = image %}
                        {% endif %}
                    {% endfor %}

                    {% if principalImage %}
                        <img src="{{ asset(principalImage.path) }}" alt="{{ principalImage.alt }}"
                             class="card-img-top" style="height: 200px; object-fit: cover;">
                    {% else %}
                        <div style="height: 200px; display: flex; align-items: center;
                                    justify-content: center; font-size: 5rem;">🚫</div>
                    {% endif %}

                    <div class="card-body">
                        <h6 class="card-title text-center">
                            <a href="{{ path('app_product', {id: product.id}) }}">
                                {{ product.title }}
                            </a>
                        </h6>
                        <p class="card-text small">
                            {{ product.description|split(' ')|slice(0, 20)|join(' ') ~ '...' }}
                        </p>
                        <div class="d-flex justify-content-between align-items-center mt-2">
                            <span class="text-muted small">{{ product.category.name }}</span>
                            <span class="badge bg-primary">{{ product.price }} €</span>
                        </div>
                    </div>
                </div>
            </div>
            {% endfor %}
        </div>
    {% endif %}

</div>
{% endblock %}
